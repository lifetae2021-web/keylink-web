rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ─────────────────────────────────────
    // 헬퍼 함수
    // ─────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return true;
    }

    match /{allPaths=**} {
      // 기존/기타 경로는 기본적으로 쓰기 차단 (필요시 추가)
      allow read, write: if false;
    }

    // users/{userId}/... 하위 경로는 본인만 업로드 가능
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && request.resource.size < 20 * 1024 * 1024; // 20MB 제한
    }
    
    // applications/{userId}/... 
    match /applications/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && request.resource.size < 20 * 1024 * 1024;
    }

    // profile_images/{userId}/... (마이페이지, 이벤트 페이지에서 사용)
    match /profile_images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && request.resource.size < 20 * 1024 * 1024;
    }

    // verification_proofs/{userId}/... (재직 증명 서류)
    match /verification_proofs/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
