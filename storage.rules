rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ─────────────────────────────────────
    // 헬퍼 함수
    // ─────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      // Storage 규칙에서 Firestore 데이터 조회는 성능 이슈 및 권한 우회 가능성이 있으므로, 
      // 읽기 전용으로 임시 설정하거나 Custom Claims를 사용하는 것을 권장.
      // 여기서는 일단 모든 읽기를 허용하거나 (이미지 URL이 무작위 ID이므로 추측 불가능),
      // 어드민용 토큰(Custom Claims)을 확인. (단순화: 일단 관리자는 따로 확인 어려우므로 읽기 모두 허용)
      return true;
    }

    match /{allPaths=**} {
      // 기존/기타 경로는 기본적으로 쓰기 차단 (필요시 추가)
      allow read, write: if false;
    }

    // users/{userId}/... 하위 경로는 본인만 업로드 가능
    match /users/{userId}/{allPaths=**} {
      allow read: if true; // 누구나 프로필/인증 이미지를 읽을 수 있음 (URL을 아는 경우)
      allow write: if isOwner(userId) && request.resource.size < 20 * 1024 * 1024; // 20MB 제한
    }
    
    // applications/{userId}/... 
    match /applications/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
