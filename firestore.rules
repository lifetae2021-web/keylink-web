rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────
    // 헬퍼 함수
    // ─────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─────────────────────────────────────
    // users 컬렉션
    // ─────────────────────────────────────
    match /users/{userId} {
      // v8.8.9: 라인업 데이터 조회를 위해 public read 허용 (클라이언트에서 노출 필터링)
      allow read: if true;
      // v7.3.3: 신규 가입(create) 허용 - 본인 UID로 생성하되, role은 반드시 'user'여야 함
      allow create: if isUser(userId) && request.resource.data.role == 'user';
      // 기존 문서 수정: 본인 수정 가능하되 role 필드 변경 불가 (관리자만 role 변경 가능)
      allow update: if isAdmin() || (isUser(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────
    // sessions (기수) 컬렉션
    // ─────────────────────────────────────
    match /sessions/{sessionId} {
      // ✅ v6.6.2: 비로그인 방문자도 읽기 가능 (홈페이지 신청 페이지 공개 노출)
      // 기수 목록은 공개 정보이므로 인증 불필요
      allow read: if true;
      // 관리자만 쓰기 가능 (기수 등록, 수정, 삭제)
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────
    // applications (신청서) 컬렉션
    // ─────────────────────────────────────
    match /applications/{applicationId} {
      // v8.8.9: 라인업(실시간 현황) 조회를 위해 public read 허용 (클라이언트에서 표출 필터링)
      allow read: if true;
      // 관리자: 모든 신청서 읽기/쓰기
      allow read, write: if isAdmin();
      // 신규 신청: 본인 UID로만 생성 가능
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────
    // votes (투표) 컬렉션
    // ─────────────────────────────────────
    match /votes/{voteId} {
      // 본인 투표만 읽기 가능
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      // 관리자: 모든 투표 읽기 (매칭 알고리즘용)
      allow read: if isAdmin();
      // 투표 제출: 본인 UID + 아직 제출하지 않은 경우에만 허용
      // (중복 방지는 복합 ID와 서버 로직으로 처리)
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────
    // matchingResults (매칭 결과) 컬렉션 — legacy, 삭제 예정
    // ─────────────────────────────────────
    match /matchingResults/{resultId} {
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        resource.data.status == 'approved';
      allow read, write: if isAdmin();
    }

    // ─────────────────────────────────────
    // matchingSummaries (매칭 요약) 컬렉션
    // ─────────────────────────────────────
    match /matchingSummaries/{sessionId} {
      // 승인된 결과는 로그인한 유저 누구나 읽기 가능 (본인 결과 필터링은 클라이언트에서)
      allow read: if isSignedIn() && resource.data.status == 'approved';
      // 관리자: 모든 읽기/쓰기
      allow read, write: if isAdmin();
    }

    // ─────────────────────────────────────
    // cms_notices (공지사항) 컬렉션
    // ─────────────────────────────────────
    match /cms_notices/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────
    // cms_faqs (FAQ) 컬렉션
    // ─────────────────────────────────────
    match /cms_faqs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────
    // cms_content (이용규정/약관/개인정보) 컬렉션
    // ─────────────────────────────────────
    match /cms_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cms_reviews/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────
    // smsTemplates (문자 템플릿) 컬렉션
    // ─────────────────────────────────────
    match /smsTemplates/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────
    // private_applications (1:1 매칭 신청) 컬렉션
    // ─────────────────────────────────────
    match /private_applications/{appId} {
      // 본인 신청서 읽기 가능
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // 신규 신청: 로그인한 유저가 본인 UID로 생성
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // 관리자: 모든 읽기/쓰기/업데이트
      allow read, write: if isAdmin();
      // 유저: 수락 액션을 위한 업데이트 (status가 profile_sent일 때만 negotiating으로 변경 허용)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid 
        && resource.data.status == 'profile_sent' 
        && request.resource.data.status == 'negotiating';
    }

  }
}
